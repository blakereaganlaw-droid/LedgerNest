# Pooled connection for runtime (Vercel Prisma Postgres marketplace)
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"

# Direct connection for migrations only
DIRECT_URL="postgresql://user:password@host:5432/db?sslmode=require"

# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-32-byte-secret"

# Production canonical URL (preview: VERCEL_URL is used automatically)
APP_URL="http://localhost:3000"

# Server-only API key for the Household CFO assistant (Anthropic).
# Never expose as a NEXT_PUBLIC_* variable. Leave unset to disable the feature.
ANTHROPIC_API_KEY=""
